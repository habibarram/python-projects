
while True:
    password = input("Enter a password: ")
    has_number = False
    for char in password:
        if char.isdigit():
            has_number = True
    if len(str(password)) < 8:
        print("Password must be at least 8 characters long.")
        continue
    if not has_number:
        print("Password must contain atleast one number.")
        continue
    else :
        print("Password is valid")
        break
    