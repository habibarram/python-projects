        name = input("Enter the name of the student: ")
        score = int(input("Enter the score of the student: "))
        status = get_grade_status(score)
        print(name, "has a score of", score, "which is", status)
        total += score
        if score > highest:
            highest = score
            highest_name = name
        if score < lowest:
            lowest = score
            lowest_name = name
average = total / students
print("Highest score: ", highest, "by", highest_name)
